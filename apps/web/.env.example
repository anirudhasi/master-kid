# ── Local API (dev) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Supabase (backend: Auth + Postgres + Storage) ─────────────────────────────
# Leave these blank to run with the in-browser MOCK auth provider (zero config).
# Fill them in (Project Settings → API) to switch to real phone-OTP auth.
# The anon key is safe to expose in the browser (RLS-gated). NEVER put the
# service-role key here — it goes only in SWA Function app settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Force an auth backend: supabase | mock. Omit to auto-select (supabase if keys set).
# VITE_AUTH_PROVIDER=mock

# Test-only "skip payment" button on the subscription step. Set to false for prod.
VITE_PAYMENTS_TEST_SKIP=true

# ── Platform admin login ──────────────────────────────────────────────────────
# Admin signs in with this phone + a password. Store only the SHA-256 hash of the
# password (never the plaintext). Generate: printf '%s' 'yourpassword' | sha256sum
# Keep these in .env.local for dev, and as GitHub Action secrets for Azure builds
# (do NOT commit real values). If unset, admin login is disabled.
VITE_ADMIN_PHONE=
VITE_ADMIN_PASSWORD_HASH=
